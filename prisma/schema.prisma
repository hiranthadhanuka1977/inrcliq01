generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AccountType {
  ADULT
  MINOR
  GUARDIAN
}

enum ApprovalStatus {
  PENDING
  APPROVED
  DECLINED
  EXPIRED
}

model User {
  id            String      @id @default(cuid())
  email         String      @unique
  emailVerified DateTime?
  firstName     String?
  lastName      String?
  handle        String?     @unique
  dateOfBirth   DateTime?
  country       String?
  region        String?
  accountType   AccountType @default(ADULT)
  signupMethod    String?
  onboardingStep  String?
  passwordHash    String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  sessions               Session[]
  accounts               Account[]
  parentApprovalRequests ParentApprovalRequest[] @relation("ChildUser")
  guardianApprovalRequests ParentApprovalRequest[] @relation("GuardianUser")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LoginCode {
  id        String    @id @default(cuid())
  email     String
  codeHash  String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([email, createdAt])
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  email     String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([email])
}

model ParentApprovalRequest {
  id                    String         @id @default(cuid())
  childUserId           String
  parentEmail           String
  guardianUserId        String?
  status                ApprovalStatus @default(PENDING)
  tokenHash             String         @unique
  expiresAt             DateTime
  sentAt                DateTime       @default(now())
  resolvedAt            DateTime?
  protectionLevel       String?
  idDocType             String?
  guardianCountry       String?
  guardianRegion        String?
  childLivesWithGuardian Boolean?
  childLocationCountry  String?
  childLocationRegion   String?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  childUser    User  @relation("ChildUser", fields: [childUserId], references: [id], onDelete: Cascade)
  guardianUser User? @relation("GuardianUser", fields: [guardianUserId], references: [id], onDelete: SetNull)

  @@index([parentEmail])
  @@index([childUserId])
  @@index([guardianUserId])
}
