DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/inrcliq?schema=public"
AUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_CLARITY_PROJECT_ID="your-clarity-project-id"

# HTTP Basic Auth (site gate — set on Vercel for demo protection)
# When BASIC_AUTH_USER and BASIC_AUTH_PASSWORD are set, the whole app requires them.
# Optionally force on/off with BASIC_AUTH_ENABLED=true|false
BASIC_AUTH_ENABLED=true
BASIC_AUTH_USER=inrcliqdemo
BASIC_AUTH_PASSWORD="inrcliqdemo@100%"

# Email (SendGrid)
EMAIL_PROVIDER=sendgrid
EMAIL_FROM=support@insider-hub.com
SENDGRID_API_KEY=your-sendgrid-api-key
