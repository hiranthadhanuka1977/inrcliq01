DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/inrcliq?schema=public"
AUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_CLARITY_PROJECT_ID="your-clarity-project-id"

# HTTP Basic Auth (site gate)
# On Vercel this is ON automatically (VERCEL=1). Locally it stays off unless enabled.
# BASIC_AUTH_ENABLED=true
# BASIC_AUTH_USER=inrcliqdemo
# BASIC_AUTH_PASSWORD="inrcliqdemo@100%"
BASIC_AUTH_ENABLED=false
BASIC_AUTH_USER=inrcliqdemo
BASIC_AUTH_PASSWORD="inrcliqdemo@100%"

# Email (Amazon SES SMTP)
# Use EMAIL_PROVIDER=console to log emails locally without sending.
EMAIL_PROVIDER=smtp
EMAIL_FROM=hello@inrcliq.com
EMAIL_FROM_NAME=InrCliq
SMTP_HOST=email-smtp.eu-north-1.amazonaws.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-ses-smtp-username
SMTP_PASS=your-ses-smtp-password
