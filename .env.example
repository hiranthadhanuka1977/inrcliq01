DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/inrcliq?schema=public"
AUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Resend (optional). Without RESEND_API_KEY, links/codes are logged to the server console only.
RESEND_API_KEY="re_..."
# Use your verified domain in production, e.g. hello@inrcliq.com
# For Resend test sending to your own inbox only: onboarding@resend.dev
EMAIL_FROM="InrCliq <onboarding@resend.dev>"
